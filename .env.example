# VMware Aria Operations — Credential Template
# Copy to ~/.vmware-aria/.env and fill in real passwords
#
# Easiest path: run `vmware-aria init` for guided setup — it writes config.yaml
# and a grep-safe (b64:) .env at mode 0600 for you, no manual editing needed.
#
# Manual path — set permissions after creating .env:
#   cp .env.example ~/.vmware-aria/.env
#   chmod 600 ~/.vmware-aria/.env
#
# Naming convention: VMWARE_ARIA_{TARGET_NAME_UPPER}_PASSWORD
#   - Replace hyphens with underscores
#   - Convert to UPPERCASE
#   - Example: target "prod-ops" → VMWARE_ARIA_PROD_OPS_PASSWORD

# Passwords for targets defined in config.yaml
VMWARE_ARIA_PROD_PASSWORD=
VMWARE_ARIA_LAB_PASSWORD=

# Add more as needed — one per target in config.yaml
# VMWARE_ARIA_DEV_PASSWORD=
